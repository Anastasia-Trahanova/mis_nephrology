# =====================================================
# Локальные настройки проекта МИС ХБП/нефрологии
# =====================================================
# Скопируйте этот файл в .env и укажите реальные значения.
# .env нельзя отправлять в Git/архивы, потому что там хранится пароль БД и session secret.

# Режим запуска:
# dev — локальная разработка;
# production — сервер с реальными пользователями.
APP_ENV=dev

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mis_for_registrations
DB_USER=postgres
DB_PASSWORD=change_me

# Пул подключений к БД
DB_POOL_MIN_CONN=1
DB_POOL_MAX_CONN=10

# Сессии FastAPI/Starlette
# Для разработки можно оставить dev-значение, для реального сервера заменить на длинную случайную строку.
SESSION_SECRET_KEY=change_me_dev_secret

# Имя cookie сессии в браузере.
SESSION_COOKIE_NAME=mis_nephrology_session

# Физический срок жизни cookie в браузере.
# Сервер всё равно не пустит пользователя, если last_seen_at старше SESSION_IDLE_TIMEOUT_SECONDS.
# 604800 = 7 дней.
SESSION_COOKIE_MAX_AGE_SECONDS=604800

# Idle timeout: через сколько секунд бездействия сессия считается истёкшей.
# 3600 = 60 минут.
SESSION_IDLE_TIMEOUT_SECONDS=3600

# Как часто JS отправляет keepalive, если врач реально вводил данные или кликал на странице.
# 180 = 3 минуты.
SESSION_KEEPALIVE_INTERVAL_SECONDS=180

# Локально false, иначе cookie Secure не будет отправляться по http://127.0.0.1:8000.
# На сервере с HTTPS поставить true.
SESSION_HTTPS_ONLY=false
